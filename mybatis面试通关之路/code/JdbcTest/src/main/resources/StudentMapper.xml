<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.davidwang456.mybatis.jdbc.mapper.StudentMapper">
	<select id="getStudentInfoById"  resultType="com.davidwang456.mybatis.jdbc.dto.StudentDTO">
	select id,first_name,last_name,age from student where id = #{id}
	</select>
</mapper>