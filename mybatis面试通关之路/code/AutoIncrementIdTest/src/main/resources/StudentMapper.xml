<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.davidwang456.mybatis.autoincrement.StudentMapper">
	<insert id="insertStudentInfo" parameterType="com.davidwang456.mybatis.autoincrement.StudentDTO" 
								  keyColumn="id"	useGeneratedKeys="true" keyProperty="id">	
		INSERT INTO `student` 
		( `first_name`, `last_name`, `age`) 
		VALUES
		(#{firstName},#{lastName},#{age})	
	</insert>
	
	<delete id="deleteById" parameterType="java.lang.Integer">
		DELETE FROM `student`  WHERE id=#{id}
	</delete>
</mapper>